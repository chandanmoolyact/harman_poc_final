<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <!-- ══════════════════════════════════════════════════════
         LEVEL 1 — PO Header Table (normal width, no scroll)
         ══════════════════════════════════════════════════════ -->
    <Table
        id="idPOTable"
        class="sapUiSizeCompact poHeaderTable"
        growing="true"
        growingThreshold="20"
        sticky="ColumnHeaders"
        items="{path: 'excelModel>/data'}"
    >
        <headerToolbar>
            <OverflowToolbar>
                <Title text="Purchase Orders" level="H5"/>
            </OverflowToolbar>
        </headerToolbar>

        <columns>
            <Column width="1.5rem" hAlign="Center"><Text text=""/></Column>
            <Column width="7rem"  hAlign="Begin"><Text text="PO Number"          tooltip="PO Number" wrapping="false"/></Column>
            <Column width="5rem"  hAlign="Begin"><Text text="Vendor"             tooltip="Vendor Code" wrapping="false"/></Column>
            <Column hAlign="Begin"><Text text="Vendor Description" tooltip="Vendor Description" wrapping="false"/></Column>
            <Column hAlign="Begin"><Text text="Status" tooltip="Status" wrapping="false"/></Column>
            <Column width="7rem"  hAlign="Center"><Text text="PO Date"           tooltip="Purchase Order Date" wrapping="false"/></Column>
            <!-- Hidden popin column — holds L2 expansion -->
            <Column minScreenWidth="10000px" demandPopin="true" popinDisplay="WithoutHeader"><Text text=""/></Column>
        </columns>

        <items>
            <ColumnListItem type="Active" press=".onShowExpanded">
                <cells>
                    <core:Icon
                        src="{= ${excelModel>PanelVisible} === true ? 'sap-icon://navigation-down-arrow' : 'sap-icon://navigation-right-arrow'}"
                        color="#3949ab" size="0.85rem"/>
                    <ObjectIdentifier title="{excelModel>PONumber}"/>
                    <Text text="{excelModel>VendorCode}"  wrapping="false"/>
                    <Text text="{excelModel>VendorName}"  wrapping="false"/>
                    <ObjectStatus inverted="true"
                    tooltip="{= ${excelModel>EDIHFlag} === 'E' ? 'EDI' : 'SAP'}"
                    text="{= ${excelModel>EDIHFlag} === 'E' ? 'EDI' : 'SAP'}"
                    state="{= ${excelModel>EDIHFlag} === 'E' ? 'Warning' : 'Information'}"/>
                    <Text text="{path: 'excelModel>PODate', formatter: '.formattter.formatDate'}" wrapping="false"/>

                    <!-- L2 expands here as a full-width popin cell -->
                    <Panel
                        visible="{excelModel>PanelVisible}"
                        backgroundDesign="Transparent"
                        width="auto">
                        <content>

                            <!-- ══════════════════════════════════════════
                                 LEVEL 2 — PO Line Items (normal width, no scroll)
                                 ══════════════════════════════════════════ -->
                            <Table
                                id="confirmationsTable"
                                class="sapUiSizeCompact poLinesTable"
                                showSeparators="All"
                                backgroundDesign="Transparent"
                                sticky="ColumnHeaders"
                                items="{excelModel>children}"
                                mode="None"
                            >
                                <headerToolbar>
                                    <OverflowToolbar style="Clear">
                                        <Title text="PO Line Items" level="H6"/>
                                    </OverflowToolbar>
                                </headerToolbar>

                                <columns>
                                    <Column width="1.5rem" hAlign="Center"><Text text=""/></Column>
                                    <Column width="3.5rem" hAlign="Center"><Text text="Item"        tooltip="PO Line Item Number" wrapping="false"/></Column>
                                    <Column width="6rem"   hAlign="Center"><Text text="Deliv. Date" tooltip="Delivery Date" wrapping="false"/></Column>
                                    <Column width="4.5rem" hAlign="End"  ><Text text="PO Qty"       tooltip="Purchase Order Quantity" wrapping="false"/></Column>
                                    <Column width="7rem"   hAlign="Begin" ><Text text="Material"     tooltip="Material Number" wrapping="false"/></Column>
                                    <Column hAlign="Begin"><Text text="Description"  tooltip="Material Description" wrapping="false"/></Column>
                                    <Column width="3.5rem" hAlign="Center"><Text text="UOM"         tooltip="Unit of Measure" wrapping="false"/></Column>
                                    <Column width="5.5rem" hAlign="End"  ><Text text="Net Price"    tooltip="Net Price" wrapping="false"/></Column>
                                    <Column width="3.5rem" hAlign="Center"><Text text="Curr."       tooltip="Currency" wrapping="false"/></Column>
                                    <Column width="3rem"   hAlign="Center"><Text text="Per"         tooltip="Price Per Unit" wrapping="false"/></Column>
                                    <!-- <Column width="5.5rem" hAlign="Begin"><Text text="Mat. Group"   tooltip="Material Group" wrapping="false"/></Column> -->
                                    <Column width="5.5rem" hAlign="Begin"><Text text="Status"   tooltip="Status" wrapping="false"/></Column>
                                    <Column width="4rem"   hAlign="Center"><Text text="Plant"       tooltip="Plant" wrapping="false"/></Column>
                                    <Column width="4.5rem" hAlign="Center"><Text text="Stor. Loc."  tooltip="Storage Location" wrapping="false"/></Column>
                                    <!-- Hidden popin column — holds L3 expansion -->
                                    <Column minScreenWidth="10000px" demandPopin="true" popinDisplay="WithoutHeader"><Text text=""/></Column>
                                </columns>

                                <items>
                                    <ColumnListItem type="Active" press=".onSubShowExpanded">
                                        <cells>
                                            <core:Icon
                                                src="{= ${excelModel>NextPanelVisible} === true ? 'sap-icon://navigation-down-arrow' : 'sap-icon://navigation-right-arrow'}"
                                                color="#00796b" size="0.8rem"/>
                                            <Text text="{excelModel>POLineItem}"      wrapping="false" tooltip="{excelModel>POLineItem}"/>
                                            <Text text="{path: 'excelModel>DeliveryDate', formatter: '.formatter.formatDate'}" wrapping="false" tooltip="{excelModel>DeliveryDate}"/>
                                            <Text text="{excelModel>POQuantity}"      wrapping="false" tooltip="{excelModel>POQuantity}"/>
                                            <Text text="{excelModel>Material}"        wrapping="false" tooltip="{excelModel>Material}"/>
                                            <Text text="{excelModel>MaterialDesc}"    wrapping="false" tooltip="{excelModel>MaterialDesc}"/>
                                            <Text text="{excelModel>UOM}"             wrapping="false" tooltip="{excelModel>UOM}"/>
                                            <Text text="{excelModel>NetPrice}"        wrapping="false" tooltip="{excelModel>NetPrice}"/>
                                            <Text text="{excelModel>Currency}"        wrapping="false" tooltip="{excelModel>Currency}"/>
                                            <Text text="{excelModel>Per}"             wrapping="false" tooltip="{excelModel>Per}"/>
                                            <!-- <Text text="{excelModel>MaterialGroup}"   wrapping="false" tooltip="{excelModel>MaterialGroup}"/> -->
                                            <!-- <Text text="{excelModel>EDILIFlag}"   wrapping="false" tooltip="{excelModel>EDILIFlag}"/> -->
                                            <ObjectStatus inverted="true"
                                                tooltip="{= ${excelModel>EDILIFlag} === 'E' ? 'EDI' : 'SAP'}"
                                                text="{= ${excelModel>EDILIFlag} === 'E' ? 'EDI' : 'SAP'}"
                                                state="{= ${excelModel>EDILIFlag} === 'E' ? 'Warning' : 'Information'}"/>
                                            <Text text="{excelModel>Plant}"           wrapping="false" tooltip="{excelModel>Plant}"/>
                                            <Text text="{excelModel>StorageLocation}" wrapping="false" tooltip="{excelModel>StorageLocation}"/>

                                            <!-- L3 expands here as a full-width popin cell -->
                                            <Panel
                                                visible="{excelModel>NextPanelVisible}"
                                                backgroundDesign="Transparent"
                                                width="auto">
                                                <content>

                                                    <!-- ══════════════════════════════════════════
                                                         LEVEL 3 — Confirmation Lines
                                                         ScrollContainer gives it its own horizontal scrollbar.
                                                         fixedLayout="Strict" + width="95rem" forces all
                                                         columns to render — the ScrollContainer scrolls them.
                                                         ══════════════════════════════════════════ -->
                                                    <VBox class="poL3Scroll">
                                                        <Table
                                                            id="idPOItemsDataTable"
                                                            class="sapUiSizeCompact poConfTable poTableNoWrap"
                                                            showSeparators="All"
                                                            backgroundDesign="Transparent"
                                                            sticky="ColumnHeaders"
                                                            fixedLayout="Strict"
                                                            width="91rem"
                                                            contextualWidth="Auto"
                                                            items="{excelModel>children}"
                                                        >
                                                            <headerToolbar>
                                                                <OverflowToolbar>
                                                                    <Button icon="sap-icon://add" type="Emphasized" tooltip="Add Row" press=".onAddVendorRowSP" class="poActionBtn poAddRowBtn"/>
                                                                    <Title text="PO Confirmation Lines" level="H6"/>
                                                                    <ToolbarSpacer/>
                                                                </OverflowToolbar>
                                                            </headerToolbar>

                                                            <columns>
                                                                <Column width="11rem"   hAlign="Center"><Text text="Action"        tooltip="Action" wrapping="false"/></Column>
                                                                <Column width="4rem"   hAlign="Begin"><Text text="EDI"        tooltip="EDI" wrapping="false"/></Column>
                                                                <Column width="5.5rem" hAlign="End"   ><Text text="Quantity"      tooltip="Confirmation Quantity" wrapping="false"/></Column>
                                                                <Column width="8rem"   hAlign="Center"><Text text="Delivery Date" tooltip="Delivery Date" wrapping="false"/></Column>
                                                                <Column width="3.5rem" hAlign="Center"><Text text="Item"          tooltip="Item Number" wrapping="false"/></Column>
                                                                <!-- <Column width="4.5rem" hAlign="Center"><Text text="HL Item"       tooltip="Higher-Level Item" wrapping="false"/></Column> -->
                                                                <Column width="4rem"   hAlign="Center"><Text text="Status"        tooltip="Status" wrapping="false"/></Column>
                                                                <Column width="3rem"   hAlign="Center"><Text text="CC"            tooltip="Confirmation Category" wrapping="false"/></Column>
                                                                <Column width="2.5rem" hAlign="Center"><Text text="D"             tooltip="Delivery Date Category" wrapping="false"/></Column>
                                                                <Column width="9rem"   hAlign="Begin" ><Text text="Reference"     tooltip="Reference Document" wrapping="false"/></Column>
                                                                <Column width="7.5rem" hAlign="Begin" ><Text text="Inbound Del."  tooltip="Inbound Delivery" wrapping="false"/></Column>
                                                                <!-- <Column width="5.5rem" hAlign="Begin" ><Text text="Batch"         tooltip="Batch Number" wrapping="false"/></Column> -->
                                                                <Column width="4.5rem" hAlign="Center"><Text text="Qty Red."      tooltip="Quantity Reduced" wrapping="false"/></Column>
                                                                <Column width="4.5rem" hAlign="Center"><Text text="MRP Rel."      tooltip="MRP Relevant" wrapping="false"/></Column>
                                                                <Column width="7.5rem" hAlign="Begin" ><Text text="MRP Material"  tooltip="MRP Material" wrapping="false"/></Column>
                                                                <Column width="2.5rem" hAlign="Center"><Text text="CI"            tooltip="Creation Indicator" wrapping="false"/></Column>
                                                                <Column width="2.5rem" hAlign="Center"><Text text="SN"            tooltip="Sequence Number" wrapping="false"/></Column>
                                                            </columns>

                                                            <items>
                                                                <ColumnListItem type="Active" press="onSubSubRowPress">
                                                                    <cells>
                                                                        <FlexBox alignItems="Center" justifyContent="Center">
                                                                            <Button
                                                                                icon="sap-icon://delete"
                                                                                type="Reject"
                                                                                tooltip="Delete this confirmation row"
                                                                                press=".onDeleteVendorTreeRow"
                                                                                enabled="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R' ? false : true }"
                                                                                class="poActionBtn"/>
                                                                            <Button
                                                                                icon="sap-icon://accept"
                                                                                type="Success"
                                                                                tooltip="Accept this confirmation row"
                                                                                press=".onAcceptVendorTreeRow"
                                                                                enabled="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'A'||${excelModel>EDIFlag} !== 'E'? false : true }"
                                                                                class="poActionBtn"/>
                                                                            <Button
                                                                                icon="sap-icon://decline"
                                                                                type="Negative"
                                                                                tooltip="Reject this confirmation row"
                                                                                press=".onRejectVendorTreeRow"
                                                                                enabled="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R'||${excelModel>EDIFlag} !== 'E'? false : true }"
                                                                                class="poActionBtn"/>
                                                                            <Button
                                                                                icon="sap-icon://comment"
                                                                                type="Emphasized"
                                                                                tooltip="Add or view remarks"
                                                                                press=".handlePopoverPress"
                                                                                enabled="{= ${excelModel>StatusFlag} !== 'R' ? false : true }"
                                                                                class="poActionBtn"/>
                                                                            <Button
                                                                                icon="sap-icon://detail-view"
                                                                                type="Emphasized"
                                                                                tooltip="Qlik Details"
                                                                                press=".handleQlikPopoverPress"
                                                                                class="poActionBtn"/>
                                                                        </FlexBox>
                                                                        <ObjectStatus inverted="true"
                                                                            tooltip="{= ${excelModel>EDIFlag} === 'E' ? 'EDI' : 'SAP'}"
                                                                            text="{= ${excelModel>EDIFlag} === 'E' ? 'EDI' : 'SAP'}"
                                                                            state="{= ${excelModel>EDIFlag} === 'E' ? 'Warning' : 'Information'}"/>
                                                                        <Input value="{
                                                                                    path: 'excelModel>Quantity',
                                                                                    type: 'sap.ui.model.type.String',
                                                                                    constraints: {
                                                                                        search: '^[0-9]+$'
                                                                                    }
                                                                                }"
                                                                                editable="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R' ? false : true }"
                                                                                tooltip="{excelModel>Quantity}"
                                                                                liveChange=".onQuantityLiveChange"/>
                                                                        <DatePicker
                                                                            valueState="{excelModel>DateState}"
                                                                            valueStateText="{excelModel>DateMsg}"
                                                                            value="{excelModel>CreationDate}"
                                                                            enabled="{= ${excelModel>ConfirmationCategory} === 'LA' || ${excelModel>StatusFlag} === 'R' ? false : true }"
                                                                            valueFormat="MM/dd/yyyy"  
                                                                            displayFormat="MM/dd/yyyy"
                                                                            placeholder="MM/DD/YYYY"
                                                                            change="onDateLiveChange"
                                                                            tooltip="{excelModel>CreationDate}"/>
                                                                        <Text text="{excelModel>Item}"                 wrapping="false"/>
                                                                        <!-- <Text text="{excelModel>HLItem}"               wrapping="false"/> -->
                                                                       <ObjectStatus inverted="true"
                                                                            tooltip="{= ${excelModel>StatusFlag} === 'R' ? 'Rejected' : (${excelModel>StatusFlag} === 'A' ? 'Approved' : 'NA')}"
                                                                            text="{= ${excelModel>StatusFlag} === 'R' ? 'Rejected' : (${excelModel>StatusFlag} === 'A' ? 'Approved' : 'NA')}"
                                                                            state="{= ${excelModel>StatusFlag} === 'R' ? 'Error' : (${excelModel>StatusFlag} === 'A' ? 'Success' : 'Information')}"/>
                                                                        <Text text="{excelModel>ConfirmationCategory}" wrapping="false"/>
                                                                        <Text text="{excelModel>FDDCategory}"          wrapping="false"/>
                                                                        <Input value="{excelModel>Reference}"    editable="{= ${excelModel>newRecFlag} === false || ${excelModel>StatusFlag} === 'R' ? false : true }" tooltip="{excelModel>Reference}"/>
                                                                        <Text text="{excelModel>InboundDelivery}"       wrapping="false"/>
                                                                        <!-- <Input value="{excelModel>Batch}"        editable="{= ${excelModel>newRecFlag} === false || ${excelModel>StatusFlag} === 'X' ? false : true }" tooltip="{excelModel>Batch}"/> -->
                                                                        <Text text="{excelModel>QtyReduced}"           wrapping="false"/>
                                                                        <Text text="{excelModel>MRPRelevant}"          wrapping="false"/>
                                                                        <Input value="{excelModel>MRPMaterial}"  editable="{= ${excelModel>newRecFlag} === false || ${excelModel>StatusFlag} === 'R' ? false : true }" tooltip="{excelModel>MRPMaterial}"/>
                                                                        <Text text="{excelModel>CreationIndicator}"    wrapping="false"/>
                                                                        <Text text="{excelModel>SequenceNumber}"       wrapping="false"/>
                                                                    </cells>
                                                                </ColumnListItem>
                                                            </items>
                                                        </Table>
                                                    </VBox>

                                                </content>
                                            </Panel>

                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>

                        </content>
                    </Panel>

                </cells>
            </ColumnListItem>
        </items>
    </Table>

</core:FragmentDefinition>