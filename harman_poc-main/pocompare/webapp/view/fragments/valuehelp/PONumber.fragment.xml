<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<SelectDialog
		noDataText="No PO Number Found"
		title="Select PO Number"
		search=".onSearch"
		searchPlaceholder="Search PO Numbers"
		confirm=".onValueHelpDialogClose"
		cancel=".onValueHelpDialogClose"
		items="{
			path: 'valueHelpModel>/POHelp'
		}">
		<StandardListItem
			title="{valueHelpModel>PONumber}"
			type="Active" />
	</SelectDialog>
</core:FragmentDefinition>